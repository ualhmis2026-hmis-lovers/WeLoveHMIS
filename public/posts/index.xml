    <item>
      <title>Ejemplo: insertar vídeo de YouTube</title>
      <link>http://localhost:1313/WeLoveHMIS/posts/ejemplo-youtube/</link>
      <pubDate>Thu, 19 Mar 2026 12:30:00 +0100</pubDate>
      <guid>http://localhost:1313/WeLoveHMIS/posts/ejemplo-youtube/</guid>
      <description>&lt;p&gt;Aquí tienes un ejemplo de cómo insertar un vídeo de YouTube usando el shortcode &lt;code&gt;youtube&lt;/code&gt;.&lt;/p&gt;&#xA;&lt;p&gt;Uso simple (posicional):&lt;/p&gt;&#xA;&lt;p&gt;Código (posicional):&lt;/p&gt;&#xA;&lt;pre tabindex=&#34;0&#34;&gt;&lt;code&gt;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&lt;div class=&#34;youtube-wrapper&#34; style=&#34;position:relative;padding-bottom:56.25%;height:0;overflow:hidden;max-width:100%;&#34;&gt;&#xD;&#xA;  &lt;iframe src=&#34;https://www.youtube.com/embed/dQw4w9WgXcQ&#34;&#xD;&#xA;    title=&#34;YouTube video&#34;&#xD;&#xA;    style=&#34;position:absolute;top:0;left:0;width:100%;height:100%;border:0;&#34;&#xD;&#xA;    allow=&#34;accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture&#34;&#xD;&#xA;    allowfullscreen loading=&#34;lazy&#34;&gt;&lt;/iframe&gt;&#xD;&#xA;&lt;/div&gt;&#xA;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;Renderizado:&lt;/p&gt;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&lt;div class=&#34;youtube-wrapper&#34; style=&#34;position:relative;padding-bottom:56.25%;height:0;overflow:hidden;max-width:100%;&#34;&gt;&#xD;&#xA;  &lt;iframe src=&#34;https://www.youtube.com/embed/dQw4w9WgXcQ&#34;&#xD;&#xA;    title=&#34;YouTube video&#34;&#xD;&#xA;    style=&#34;position:absolute;top:0;left:0;width:100%;height:100%;border:0;&#34;&#xD;&#xA;    allow=&#34;accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture&#34;&#xD;&#xA;    allowfullscreen loading=&#34;lazy&#34;&gt;&lt;/iframe&gt;&#xD;&#xA;&lt;/div&gt;&#xA;&lt;p&gt;Uso con nombre y título (mejor legibilidad):&lt;/p&gt;&#xA;&lt;p&gt;Código (nombrado):&lt;/p&gt;&#xA;&lt;pre tabindex=&#34;0&#34;&gt;&lt;code&gt;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&lt;div class=&#34;youtube-wrapper&#34; style=&#34;position:relative;padding-bottom:56.25%;height:0;overflow:hidden;max-width:100%;&#34;&gt;&#xD;&#xA;  &lt;iframe src=&#34;https://www.youtube.com/embed/dQw4w9WgXcQ&#34;&#xD;&#xA;    title=&#34;Ejemplo vídeo&#34;&#xD;&#xA;    style=&#34;position:absolute;top:0;left:0;width:100%;height:100%;border:0;&#34;&#xD;&#xA;    allow=&#34;accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture&#34;&#xD;&#xA;    allowfullscreen loading=&#34;lazy&#34;&gt;&lt;/iframe&gt;&#xD;&#xA;&lt;/div&gt;&#xA;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;Renderizado:&lt;/p&gt;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&lt;div class=&#34;youtube-wrapper&#34; style=&#34;position:relative;padding-bottom:56.25%;height:0;overflow:hidden;max-width:100%;&#34;&gt;&#xD;&#xA;  &lt;iframe src=&#34;https://www.youtube.com/embed/dQw4w9WgXcQ&#34;&#xD;&#xA;    title=&#34;Ejemplo vídeo&#34;&#xD;&#xA;    style=&#34;position:absolute;top:0;left:0;width:100%;height:100%;border:0;&#34;&#xD;&#xA;    allow=&#34;accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture&#34;&#xD;&#xA;    allowfullscreen loading=&#34;lazy&#34;&gt;&lt;/iframe&gt;&#xD;&#xA;&lt;/div&gt;&#xA;&lt;p&gt;Uso con inicio en segundo 30:&lt;/p&gt;&#xA;&lt;p&gt;Código (inicio en 30s):&lt;/p&gt;&#xA;&lt;pre tabindex=&#34;0&#34;&gt;&lt;code&gt;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&lt;div class=&#34;youtube-wrapper&#34; style=&#34;position:relative;padding-bottom:56.25%;height:0;overflow:hidden;max-width:100%;&#34;&gt;&#xD;&#xA;  &lt;iframe src=&#34;https://www.youtube.com/embed/dQw4w9WgXcQ?start=30&#34;&#xD;&#xA;    title=&#34;YouTube video&#34;&#xD;&#xA;    style=&#34;position:absolute;top:0;left:0;width:100%;height:100%;border:0;&#34;&#xD;&#xA;    allow=&#34;accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture&#34;&#xD;&#xA;    allowfullscreen loading=&#34;lazy&#34;&gt;&lt;/iframe&gt;&#xD;&#xA;&lt;/div&gt;&#xA;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;Renderizado:&lt;/p&gt;</description>
    </item>
